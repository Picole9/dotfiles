conky.config = {
	use_xft = true,
	font = 'Zekton:size=10',

	own_window = true,
	own_window_type = 'normal',
	own_window_transparent = true,
	own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',
	own_window_colour = '#000000',
	own_window_argb_visual = true,
	own_window_argb_value = 0,

	double_buffer = true,
	minimum_width = 500, minimum_height = 412,
	draw_shades = false,
	draw_outline = false,
	draw_borders = false,
	default_color = 'white',
	default_shade_color = 'black',
	default_outline_color = 'green',
	alignment = 'top_right',
	gap_x = 40,
	gap_y = 50,
	no_buffers = true,
	uppercase = false,
	cpu_avg_samples = 2,
	net_avg_samples = 1,
	override_utf8_locale = true
};

conky.text = [[
${goto 420}${voffset -8}${color}${font Zekton:style=bold:size=12}Specht${font}
${alignc -70}${voffset 20}Temp:
${alignc -70}${hwmon 4 temp 2}°C
${alignr 180}${voffset 60}${font Zekton:style=bold:size=35}${time %H:%M}${font}
${alignc -153}${voffset -10}Akku
${alignc -153}${battery_percent BAT1}%
${alignc -30}${voffset 30}CPU
${alignc -30}${cpu}%
${alignc -110}${voffset -40}${color}RAM
${alignc -110}${memperc}%
  ${alignc -70}${voffset 22}HD
${alignc -70}${fs_used_perc /}%

${image /home/specht/.config/conky/lsd.png -p 234,0 -s 255x412}
]];
